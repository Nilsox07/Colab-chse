{
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/admin/admin\\.css", "dest": "/admin/admin.css" },
    { "src": "/robots\\.txt", "dest": "/robots.txt" },
    { "src": "/llms\\.txt", "dest": "/llms.txt" },
    { "src": "/sitemap\\.php", "dest": "/api/sitemap.php" },
    { "src": "/install\\.php", "dest": "/api/install.php" },
    { "src": "/admin(/.*)?", "dest": "/api/admin.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
